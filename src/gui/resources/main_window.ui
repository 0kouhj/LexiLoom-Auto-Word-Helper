                <property name="layoutDirection">
                 <enum>Qt::LayoutDirection::LeftToRight</enum>
                </property>
                <property name="styleSheet">
                 <string notr="true">/* 1. ComboBox 本体 */
QComboBox {
    border: 1px solid rgba(0, 0, 0, 185); 
    border-radius: 8px;
    padding: 2px 10px;
    background-color: #ffffff;
    color: #333333;
    font-size: 14px;
    min-width: 100px;
}

/* 2. 悬停和打开时的边框颜色 */
QComboBox:hover {
    border: 1px solid #0078d7;
}

QComboBox:on { /* 展开时的状态 */
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
}

/* 1. 下拉区域 */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border: none;
}

/* 2. 核心：画一条横线 */
QComboBox::down-arrow {
    image: none; 
    background-color: #666666; /* 横线的颜色 */
    width: 10px;               /* 横线的长度 */
    height: 2px;               /* 横线的粗细 */
    
    /* 这里的 margin 可以微调横线在格子里的位置 */
    margin-right: 10px; 
}


/* 5. 下拉出来的列表框本体 */
QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    selection-background-color: #0078d7; /* 选中项背景 */
    selection-color: #ffffff;            /* 选中项文字 */
    outline: none;                       /* 去掉虚线框 */
}

/* 6. 下拉列表里的每一项 */
QComboBox QAbstractItemView::item {
    min-height: 30px;
    padding-left: 10px;
}</string>
