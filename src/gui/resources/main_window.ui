   <string notr="true">QPushButton {
    /* 格式：宽度 实线 颜色(使用rgba实现半透明) */
    border: 1px solid rgba(0, 0, 0, 185); 
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 150);
}
/* 鼠标悬停时的状态 */
QPushButton:hover {
    border: 2px solid rgba(74, 144, 226, 180); 
	background-color: rgba(0, 120, 215, 0.1);
    color: #2d5a89; 
}

/* 鼠标按下时的状态（可选，增加点击反馈） */
QPushButton:pressed {
    background-color: rgba(135, 206, 250, 255);
    border: 2px solid rgba(74, 144, 226, 255);
}

QMainWindow{margin:0px;
	padding:0px;}
</string>
