         <property name="styleSheet">
          <string notr="true">/* 1. 列表整体容器 */
QListWidget {
    background-color: rgba(255,255,255,0); /* 背景透明，由父级 GroupBox 决定
 */
	border-radius:8px;
	font-weight: bold;
    border: none;                  /* 去掉外边框 */
    outline: none;                 /* 去掉点击时的虚线框 */
    padding: 10px 5px;             /* 上下留点呼吸空间 */
}

/* 2. 每一个导航选项（未选中状态） */
QListWidget::item {
    background-color: transparent;
    color: #FFFFFF;                /* 深灰色文字 */
    border-radius: 6px;            /* 圆角矩形 */
    margin-bottom: 8px;            /* 每个按钮之间的纵向间距 */
    padding-top:10px;
	padding-bottom:10px;
	padding-left:8px;
	padding-right:8px;
    border: 1px solid transparent; /* 预留边框位置防止闪烁 */
}

/* 3. 鼠标悬停（未选中时） */
QListWidget::item:hover {
    background-color: rgba(0, 0, 0, 0.06); /* 极浅的灰色遮罩 */
    color: #000000;
}

/* 4. 选中状态（重点） */
QListWidget::item:selected {
    background-color: #cbdcf7;     /* PCL 经典的蓝色（或者你喜欢的强调色） */
    color: #000000;                /* 选中后文字变白 */
    font-weight: bold;             /* 选中后加粗 */
}

/* 5. 选中且鼠标悬停 */
QListWidget::item:selected:hover {
    background-color: #a5c5f7;     /* 颜色稍微深一点点 */
}</string>
         </property>
